# =========================
# 应用基础配置
# =========================
APP_NAME=企业智能办公助手
APP_VERSION=1.0.0
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api
PUBLIC_API_BASE_URL=http://localhost:8000/api

# 前端开发地址
FRONTEND_URL=http://localhost:5173

# 允许跨域的来源地址
# 如需多个地址，未来可以改成 JSON 数组，例如 ["http://localhost:5173","http://127.0.0.1:5173"]
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# =========================
# 大模型供应方（OpenAI 协议 或 Anthropic 协议）
# =========================
# 显式指定走哪条协议；留空则按下面填了哪个 key 自动判断。
# 可选值：openai / anthropic
LLM_PROVIDER=

# --- OpenAI 协议（OpenAI 官方 / MiniMax 按量计费 / 其他 OpenAI 兼容网关）---
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
# 用 OpenAI 官方留空即可；用 MiniMax 按量计费填 https://api.minimaxi.com/v1
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o
# 如果当前模型供应商没有 Embedding 接口，可以留空。
# 留空后知识库会自动退回到本地词法检索，不影响项目跑起来。
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic 协议（Claude 官方 / MiniMax Token Plan 或 Coding Plan 的 sk-cp- key）---
# 注意：Token Plan key 只能走这一段，不能放进 OPENAI_API_KEY，否则会 401。
ANTHROPIC_API_KEY=
# 用 Claude 官方留空；用 MiniMax 国内站填 https://api.minimaxi.com/anthropic
ANTHROPIC_BASE_URL=
# Claude 官方推荐 claude-3-5-sonnet-latest；MiniMax Coding Plan 用 MiniMax-M2.7
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# 推理模型（Claude 3.7+ extended thinking / MiniMax M2.x）的思考预算 token 数。
# 0 = 关闭 thinking 通道；> 0 = 打开，模型会把推理过程实时流给 UI 折叠块。
# 仅作用于"生成最终答案"那一步，意图分类/抽取/grading 等链路始终关闭以保证 JSON 稳定。
ANTHROPIC_THINKING_BUDGET=4000
# 开启 thinking 时单次响应的最大 token 上限，必须大于 ANTHROPIC_THINKING_BUDGET。
ANTHROPIC_MAX_TOKENS=8192

LANGSMITH_TRACING_V2=false
LANGSMITH_API_KEY=<YOUR_LANGSMITH_API_KEY>
LANGSMITH_PROJECT=ruirui-office-assistant
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# =========================
# PostgreSQL
# =========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ruirui
POSTGRES_USER=ruirui
POSTGRES_PASSWORD=ruirui
BUSINESS_DB_BACKEND=auto
POSTGRES_CONNECT_TIMEOUT_SECONDS=2

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =========================
# Milvus
# =========================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_SECURE=false
MILVUS_COLLECTION_NAME=enterprise_knowledge

# =========================
# 商旅接口
# =========================
# 如果你暂时没有真实商旅接口地址，这一段保持为空即可。
# 系统会自动回退到本地订单确认逻辑，不会阻塞项目运行。
TRAVEL_API_BASE_URL=
TRAVEL_API_PATH=/orders
TRAVEL_API_AUTH_TOKEN=
TRAVEL_API_TIMEOUT_SECONDS=10
TRAVEL_API_FALLBACK_ENABLED=true

# 默认演示部门
DEFAULT_DEPARTMENT=HR
