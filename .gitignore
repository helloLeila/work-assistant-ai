# Python 运行缓存
__pycache__/
*.py[cod]

# Python 虚拟环境
.venv/
venv/

# 前端依赖与构建产物
frontend/node_modules/
frontend/dist/

# 后端测试与构建产物
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# 本地环境变量与历史备份
.env
.env.bak
.env.bak.*
.env.local
.env.*.local
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# 临时探针 / 一次性脚本（含真实接口探测）
scripts/probe_key.py

# Docker 挂载数据
volumes/

# macOS 系统文件
.DS_Store

# IDE / 编辑器本地配置
.idea/
backend/.idea/
.vscode/
*.swp

# 本地 AI 代理工具配置（与项目无关）
.codex/
.windsurf/

# 后端运行期产物（向量索引、用户上传文件、运行时数据等）
# - knowledge_index/ 是 Milvus 不可用时的本地向量索引，启动会自动重建
# - uploads/ 是终端用户上传的文档，不属于代码资产
# - *.db / *.json 是运行时生成的数据和会话历史，每次运行都会变化
backend/data/knowledge_index/
backend/data/uploads/
backend/data/*.db
backend/data/*.json
