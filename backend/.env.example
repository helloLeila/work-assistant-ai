# =========================
# 后端应用基础配置
# =========================
APP_NAME=企业智能办公助手
APP_VERSION=1.0.0
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api
PUBLIC_API_BASE_URL=http://localhost:8000/api

# 前端开发地址
FRONTEND_URL=http://localhost:5173

# 允许跨域的来源地址
# 如需多个地址，未来可以改成 JSON 数组，例如 ["http://localhost:5173","http://127.0.0.1:5173"]
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# =========================
# 大模型供应方（OpenAI 协议 或 Anthropic 协议）
# =========================
# 显式指定走哪条协议；留空则按下面填了哪个 key 自动判断。
# 可选值：openai / anthropic
LLM_PROVIDER=

# --- OpenAI 协议（OpenAI 官方 / MiniMax 按量计费 / 其他 OpenAI 兼容网关）---
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
# 用 OpenAI 官方留空即可；用 MiniMax 按量计费填 https://api.minimaxi.com/v1
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o
# 轻量 utility 模型：用于意图分类、结构化抽取、评分等小链路。
OPENAI_UTILITY_MODEL=gpt-4o-mini
# 如果当前模型供应商没有 Embedding 接口，可以留空。
# 留空后知识库会自动退回到本地词法检索，不影响项目跑起来。
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic 协议（Claude 官方 / MiniMax Token Plan 或 Coding Plan 的 sk-cp- key）---
# 注意：Token Plan key 只能走这一段，不能放进 OPENAI_API_KEY，否则会 401。
ANTHROPIC_API_KEY=
# 用 Claude 官方留空；用 MiniMax 国内站填 https://api.minimaxi.com/anthropic
ANTHROPIC_BASE_URL=
# Claude 官方推荐 claude-3-5-sonnet-latest；MiniMax Coding Plan 用 MiniMax-M2.7
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# Anthropic 侧轻量模型；如果供应商只暴露一个模型，可以留空让系统回退到主模型。
ANTHROPIC_UTILITY_MODEL=
# 推理模型（Claude 3.7+ extended thinking / MiniMax M2.x）的思考预算 token 数。
ANTHROPIC_THINKING_BUDGET=4000
# 开启 thinking 时单次响应的最大 token 上限（thinking + 答案 总额度）。
ANTHROPIC_MAX_TOKENS=8192
# 关闭 thinking 时纯答案的输出预算（中文 ~1.5 字/token，4096 tokens ≈ 2700 字）。
ANTHROPIC_OUTPUT_TOKENS=4096

LANGSMITH_TRACING_V2=false
LANGSMITH_API_KEY=<YOUR_LANGSMITH_API_KEY>
LANGSMITH_PROJECT=ruirui-office-assistant
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

JWT_SECRET_KEY=ruirui-access-secret
JWT_REFRESH_SECRET_KEY=ruirui-refresh-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================
# PostgreSQL
# =========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ruirui
POSTGRES_USER=ruirui
POSTGRES_PASSWORD=ruirui
BUSINESS_DB_BACKEND=auto
POSTGRES_CONNECT_TIMEOUT_SECONDS=2

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =========================
# Milvus
# =========================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_SECURE=false
MILVUS_COLLECTION_NAME=enterprise_knowledge

# =========================
# 商旅接口
# =========================
# 如果你暂时没有真实商旅接口地址，这一段保持为空即可。
# 系统会自动回退到本地订单确认逻辑，不会阻塞项目运行。
TRAVEL_API_BASE_URL=
TRAVEL_API_PATH=/orders
TRAVEL_API_AUTH_TOKEN=
TRAVEL_API_TIMEOUT_SECONDS=10
TRAVEL_API_FALLBACK_ENABLED=true

# =========================
# Bocha Web Search（联网检索）
# =========================
# 留空 BOCHA_API_KEY 时，web_research_write 路径会自动降级到 direct_write。
BOCHA_API_KEY=
BOCHA_BASE_URL=https://api.bocha.cn/v1
BOCHA_MAX_RESULTS=5
BOCHA_TIMEOUT_SECONDS=1.5
BOCHA_FRESHNESS=oneMonth

# 默认演示部门
DEFAULT_DEPARTMENT=HR

# =========================
# 企业知识库 RAG 核心配置
# =========================
KNOWLEDGE_CHUNK_SIZE=512
KNOWLEDGE_CHUNK_OVERLAP=128
KNOWLEDGE_REWRITE_RETRY_MAX=1
KNOWLEDGE_RRF_RANK_CONSTANT=60
KNOWLEDGE_RERANK_TOP_K=5
KNOWLEDGE_RERANK_INPUT_MAX=50
KNOWLEDGE_RERANK_INPUT_HIGH_RECALL_MAX=80
KNOWLEDGE_RETRIEVAL_PROFILE=standard
KNOWLEDGE_BIAS_MODE=balanced
KNOWLEDGE_LOW_RECALL_THRESHOLD=5
KNOWLEDGE_LOW_CONFIDENCE_THRESHOLD=3
KNOWLEDGE_HISTORY_LOOKUP_ENABLED=true
RETRIEVAL_DEBUG_TRACE_RETENTION_DAYS=7
ACCESS_AUDIT_LOG_RETENTION_DAYS=180
USER_BEHAVIOR_LOG_RETENTION_DAYS=30
